# =============================================
# Priao VIP Catalog — .gitignore
# =============================================

# -------- OS / System --------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# -------- Editors / IDEs --------
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.cursor/

# -------- Backup / Old files --------
*.bak
*.backup
*.old
*.orig
index.original.html*

# -------- Python (backoffice/convert.py) --------
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# -------- Excel temp files --------
~$*.xlsx
~$*.xls
~$*.docx

# -------- Generated reports (ไม่ต้อง commit) --------
conversion_report.md
backoffice/conversion_report.md
*.report.md

# -------- Node (เผื่อใช้ build tool ในอนาคต) --------
node_modules/
package-lock.json
yarn.lock
.npm/
.yarn/

# -------- Logs --------
*.log
logs/
npm-debug.log*
yarn-debug.log*

# -------- Env / Secrets --------
.env
.env.local
.env.*.local

# -------- Test / Output dir --------
/tmp/
*.tmp
test_out/
dist/
build/


# -------- 🔒 Local-only folder (DO NOT PUSH) --------
# Documentation + design references + internal tools — เก็บไว้ local เท่านั้น
# ดู !@Don't Push/README.md
!@Don't Push/
"!@Don't Push/"
