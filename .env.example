# ============================================================
# ERP Database Connection — refresh_suggested_retail.py
# ============================================================
#
# Setup:
#   1. Copy this file to .env (same folder)
#   2. ใส่ค่าจริง (ขอจาก DBA / IT Manager)
#   3. รัน: python refresh_suggested_retail.py
#
# 🔒 SECURITY:
#   - ห้าม commit .env (อยู่ใน .gitignore แล้ว)
#   - ห้ามแชร์ค่าทาง LINE/Email — ใช้ password manager
#   - ใช้ READ-ONLY user เท่านั้น (ไม่ต้องการ write)
# ============================================================

# ERP PostgreSQL host
# ตัวอย่าง: erp-priao.cluster-xxx.ap-southeast-1.rds.amazonaws.com
ERP_DB_HOST=your-erp-host.example.com

# Port (default 5432)
ERP_DB_PORT=5432

# Database name
ERP_DB_NAME=priao-production

# Read-only user (ขอจาก DBA — สิทธิ์ SELECT เท่านั้น)
ERP_DB_USER=catalog_readonly

# Password
ERP_DB_PASSWORD=replace-with-actual-password
